datasource db {
    provider = "postgresql"
    url      = env("RENT_DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
    output   = "../generated/rentClient"
}

model RentProducts {
    product_id    Int      @id @default(autoincrement())
    title         String
    description   String
    price_per_day Int
    college       String
    category      String
    location      String
    type          String   @default("RENT")
    seller_id     String
    seller_name   String
    image_urls   String[]   // array of strings
    created_at    DateTime @default(now())
}
