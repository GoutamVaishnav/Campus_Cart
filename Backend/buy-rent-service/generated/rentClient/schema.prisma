datasource db {
  provider = "postgresql"
  url      = env("RENT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/rentClient"
}

model RentProducts {
  product_id    Int      @id @default(autoincrement())
  title         String
  description   String
  price_per_day Int
  college       String
  category      String
  location      String
  seller_id     Int
  seller_name   String
  image_url     String
  created_at    DateTime @default(now())
}
