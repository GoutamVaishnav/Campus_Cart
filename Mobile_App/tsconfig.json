{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "app/index.jsx",
    "app/splash.jsx",
    "app/(auth)/login.tsx",
    "app/(auth)/verify-otp.jsx",
    "app/(auth)/signup.jsx"
, "app/(tabs)/index.jsx", "app/(tabs)/_layout.jsx"  ]
}
